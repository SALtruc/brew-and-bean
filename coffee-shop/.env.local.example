# AWS Region
AWS_REGION=ap-southeast-1

# DynamoDB
DYNAMODB_ORDERS_TABLE=CoffeeOrders

# S3 - public bucket base URL for product images
# Example: https://my-coffee-bucket.s3.ap-southeast-1.amazonaws.com
NEXT_PUBLIC_S3_BASE_URL=

# AWS credentials (only set these for local dev; on EC2 use IAM role instead)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

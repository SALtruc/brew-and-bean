# AWS Region
AWS_REGION=ap-southeast-1

# DynamoDB
DYNAMODB_ORDERS_TABLE=CoffeeOrders

# S3 - set S3_BUCKET_NAME to let the server create image URLs via AWS SDK.
# Leave blank to use the built-in Unsplash fallback images.
S3_BUCKET_NAME=
S3_PRESIGNED_URL_TTL_SECONDS=3600

# Optional: if your bucket/CDN is public, this URL is used instead of presigned URLs.
# Example: https://my-coffee-bucket.s3.ap-southeast-1.amazonaws.com
NEXT_PUBLIC_S3_BASE_URL=

# AWS credentials are optional.
# Leave them unset to let the AWS SDK use the default credential chain
# (EC2 IAM role, AWS_PROFILE, SSO, web identity, etc.).
# Only uncomment these for local dev with a manually created IAM access key.
# AWS_ACCESS_KEY_ID=your_access_key_id_here
# AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

